# ==================== Auction Bot ====================
# Copy this file to .env and fill in your values

# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_channel_id_here
ADMIN_CHAT_ID=your_user_id_here

# Web Dashboard Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=change_this_password

# Flask Secret Key (generate a random string)
SECRET_KEY=change-this-to-a-random-secret-key

# Persistent Bot Configuration (Recommended for Render/Docker ephemeral hosts)
# Overrides settings in bot_config.json if set in environment variables
# BOT_TARGET_URLS=https://auction.et/category/auctions/38,https://auction.et/category/auctions/39
# BOT_CHECK_INTERVAL=300
# BOT_HOURLY_POST_LIMIT=10
# BOT_MIN_PRICE=1000
# BOT_MAX_PRICE=500000
# BOT_AUCTION_TYPES=Open Bidding,Sealed Bid
# BOT_INCLUDE_KEYWORDS=toyota,hyundai
# BOT_EXCLUDE_KEYWORDS=damaged,parts
# BOT_BUSINESS_HOURS_START=09:00
# BOT_BUSINESS_HOURS_END=17:00
# BOT_BUSINESS_DAYS=0,1,2,3,4
# BOT_CHAT_IDS=your_channel_id_here
# BOT_POST_TEMPLATE=📢 <b>New Auction!</b>\n\n📦 <b>Asset:</b> {name}\n🔗 <a href='{target_url}'>View details</a>
